# backup-before-troubleshooting — example config (placeholders only)
#
# Optional. The only setting is where recovery workspaces are created.
#
# Override either way:
#   - export RECOVERY_ROOT in your shell, or
#   - copy this file to ~/.config/backup-before-troubleshooting/config.env and set it there.
#
# Default when unset: ~/Recovery
#
# Do NOT point this at ~/Downloads or ~/Desktop. Those are iCloud-managed and can be evicted
# by "Optimize Mac Storage", which would silently corrupt the forensic record you are trying
# to protect. Pick a location that is always materialized locally.

RECOVERY_ROOT=~/Recovery
