# rubicon-wordpress-version-lab — example config (placeholders only)
#
# Do NOT edit this file for real use. Instead, create your private config with:
#
#   scripts/config_wp_lab.sh --set \
#     --ssh-host  myNAS \
#     --access-host nas.example.lan
#
# That writes ~/.config/rubicon-wp-lab/config.env (mode 600), which is read by
# every command. This file is only documentation of the available keys.
#
# Only non-secret infrastructure/identity values live here. Per-lab database
# and admin passwords are generated per lab and written to that lab's
# credentials.txt on the NAS (mode 600) — never stored in this config.

# SSH target: an ssh alias from ~/.ssh/config, or user@host.  REQUIRED.
SSH_HOST=myNAS

# Host you browse to. Becomes the WordPress site URL (siteurl/home), so use the
# name you actually open in a browser — an IP or a LAN hostname.  REQUIRED.
ACCESS_HOST=nas.example.lan

# Parent directory for labs on the NAS. Each lab lives at
# <BASE_PARENT>/<site-name>/config.  Default: /volume1/docker
BASE_PARENT=/volume1/docker

# Shared external docker network for all labs.  Default: wordpress_lab_default
NETWORK_NAME=wordpress_lab_default

# Default WordPress admin user / email (overridable per lab).
ADMIN_USER=admin
ADMIN_EMAIL=admin@example.com

# Container timezone and umask.
TZ=UTC
UMASK=002
